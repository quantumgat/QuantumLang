pub struct ParallelLoopHighLevelE2eProof {
  parserAcceptsMemberKeyword: bool,
  pipeBodyParsed: bool,
  stopLowersToValueBreak: bool,
  nativeMarkerEmitted: bool,
  executableFixture: string,
  exitCode: i64,
