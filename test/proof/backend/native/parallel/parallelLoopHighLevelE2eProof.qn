    pipeBodyParsed: pipeBodyParsed,
    stopLowersToValueBreak: stopLowersToValueBreak,
    nativeMarkerEmitted: nativeMarkerEmitted,
    executableFixture: "parallel_loop_highlevel_e2e_ok.qn",
    exitCode: exitCode,
    noGeneratedFallback: true,
