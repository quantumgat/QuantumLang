}

impl ParallelLoopHighLevelE2eProof {
  pub fn accepted(self: ParallelLoopHighLevelE2eProof) -> bool {
    return self.parserAcceptsMemberKeyword
      && self.pipeBodyParsed
      && self.stopLowersToValueBreak
