pub fn parallelLoopHighLevelE2eProof(
  parserAcceptsMemberKeyword: bool,
  pipeBodyParsed: bool,
  stopLowersToValueBreak: bool,
  nativeMarkerEmitted: bool,
  exitCode: i64,
) -> ParallelLoopHighLevelE2eProof {
  return ParallelLoopHighLevelE2eProof {
