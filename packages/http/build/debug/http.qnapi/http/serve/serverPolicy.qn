// qtlc package API surface for http; bodies are supplied by the native package archive.
pub struct ServerPolicy {
  workers: usize
  workersExplicit: bool
  timeoutSeconds: usize
  accessLog: bool
  metrics: bool
  maxBodyBytes: usize
  mode: HttpTransportMode
  modeExplicit: bool
  blockingPoolWorkers: usize
  blockingPoolConfigured: bool
}
