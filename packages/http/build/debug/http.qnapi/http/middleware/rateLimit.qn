// qtlc package API surface for http; bodies are supplied by the native package archive.
pub enum RateLimitKind {
  FixedWindow,
  TokenBucket,
}
pub struct RateLimitPolicy {
  kind: RateLimitKind
  limit: usize
  windowSeconds: usize
  emitStandardHeaders: bool
  retryAfter: bool
}
pub struct RateLimit {
}
