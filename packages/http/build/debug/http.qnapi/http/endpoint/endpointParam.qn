// qtlc package API surface for http; bodies are supplied by the native package archive.
pub enum EndpointParamSource {
  Path,
  Query,
  Body,
  Header,
  Capability,
  Context,
  Request,
  Response,
}
pub struct EndpointParam {
  name: string
  typeName: string
  source: EndpointParamSource
  required: bool
}
