pub struct BuiltinPrimitiveType {
  typeId: BuiltinPrimitiveTypeId,
  spelling: string,
  kind: BuiltinPrimitiveKind,
  bitWidth: usize,
  abiSize: usize,
  abiAlign: usize,
  signed: bool,
  targetSupported: bool,
}

pub fn builtinPrimitiveType(
  typeId: BuiltinPrimitiveTypeId,
  spelling: string,
  kind: BuiltinPrimitiveKind,
  bitWidth: usize,
  abiSize: usize,
  abiAlign: usize,
  signed: bool,
  targetSupported: bool
) -> BuiltinPrimitiveType {
  return BuiltinPrimitiveType {
    typeId: typeId,
    spelling: spelling,
    kind: kind,
    bitWidth: bitWidth,
    abiSize: abiSize,
    abiAlign: abiAlign,
    signed: signed,
    targetSupported: targetSupported,
  }
}

impl BuiltinPrimitiveType {
  pub fn sourceSpelling(self: BuiltinPrimitiveType) -> string {
    return self.spelling
  }

  pub fn primitiveKind(self: BuiltinPrimitiveType) -> BuiltinPrimitiveKind {
    return self.kind
  }

  pub fn width(self: BuiltinPrimitiveType) -> usize {
    return self.bitWidth
  }

  pub fn layoutSize(self: BuiltinPrimitiveType) -> usize {
    return self.abiSize
  }

  pub fn layoutAlign(self: BuiltinPrimitiveType) -> usize {
    return self.abiAlign
  }

  pub fn isSigned(self: BuiltinPrimitiveType) -> bool {
    return self.signed
  }

  pub fn isTargetSupported(self: BuiltinPrimitiveType) -> bool {
    return self.targetSupported
  }
}

pub fn requiredBuiltinPrimitiveTypeCount() -> usize {
  return 61
}
