  I8
  I16
  I32
  I64
  I128
  I256
  ISize
  U8
  U16
  U32
  U64
  U128
  U256
  USize
  F16
  F32
  F64
  F128
  Dec64
  Dec128
  Dec256
  Dec
  Decimal
  BigInt
  BigUint
  Complex64
  Complex128
  Complex256
  Complex
  Rational64
  Rational
  Fixed
  SimdI64x4
  SimdU64x4
  Vector2F64
  Vector3F64
  Matrix2x2F64
  Matrix3x3F64
  Tensor2x2x2F64
  Tensor3x3x3F64
  PrimeField64
  OverflowI64
