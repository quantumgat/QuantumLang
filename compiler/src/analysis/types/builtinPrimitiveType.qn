  SignedInteger
  UnsignedInteger
  Float
  Decimal
  BigInteger
  Complex
  Rational
  Fixed
  Simd
  Vector
  Matrix
  Tensor
  FiniteField
  Overflow
  CoreScalar
  TextBytes
  Quantum
}

