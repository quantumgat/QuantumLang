pub enum LowLevelErrorDiagnosticKind {
  Memory
  Pointer
  Unsafe
  Atomic
  Simd
  Layout
  Ffi
  CoredumpRisk
  DoubleFreeRisk
}

pub struct LowLevelErrorDiagnostic {
  kind: LowLevelErrorDiagnosticKind,
  diagnostic: Diagnostic,
  machine: MachineDiagnostic,
  proof: ProofDiagnostic,
  fixIt: FixIt,
  range: SourceRange,
  safeFixItOnly: bool,
  noCoredumpPath: bool,
  redacted: bool,
}

pub fn lowLevelErrorDiagnostic(
  kind: LowLevelErrorDiagnosticKind,
  file: u32,
  start: usize,
  end: usize,
  message: string,
  replacement: string,
) -> LowLevelErrorDiagnostic {
  let range = SourceRange.init(file, start, end)
  let diagnostic = Diagnostic.model(
    diagnosticCode("LOW", kind.codeNumber()),
    kind.category(),
    DiagnosticSeverity.Error,
    range,
    message
  )
  let proof = ProofDiagnostic.init(
    kind.proofKind(),
    kind.proofCode(),
    range,
    ProofExplanation.init(kind.ruleName(), message, range)
  )
  let fixIt = FixIt.init(range, replacement, FixItSafety.Safe)
  return LowLevelErrorDiagnostic {
    kind: kind,
    diagnostic: diagnostic,
    machine: MachineDiagnostic.fromDiagnostic(diagnostic),
    proof: proof,
    fixIt: fixIt,
    range: range,
    safeFixItOnly: true,
    noCoredumpPath: true,
    redacted: true,
  }
}

pub fn memoryErrorDiagnostic(file: u32, start: usize, end: usize, message: string) -> LowLevelErrorDiagnostic {
  return lowLevelErrorDiagnostic(
    LowLevelErrorDiagnosticKind.Memory,
    file,
    start,
    end,
    message,
    "use a checked allocator domain or owned handle"
  )
}

pub fn pointerErrorDiagnostic(file: u32, start: usize, end: usize, message: string) -> LowLevelErrorDiagnostic {
  return lowLevelErrorDiagnostic(
    LowLevelErrorDiagnosticKind.Pointer,
    file,
    start,
    end,
    message,
    "use Ptr.get()? or NonNull<T> after a null check"
  )
}

pub fn unsafeErrorDiagnostic(file: u32, start: usize, end: usize, message: string) -> LowLevelErrorDiagnostic {
  return lowLevelErrorDiagnostic(
    LowLevelErrorDiagnosticKind.Unsafe,
    file,
    start,
    end,
    message,
    "move the operation into an unsafe block with a proof obligation"
  )
}

pub fn atomicErrorDiagnostic(file: u32, start: usize, end: usize, message: string) -> LowLevelErrorDiagnostic {
  return lowLevelErrorDiagnostic(
    LowLevelErrorDiagnosticKind.Atomic,
    file,
    start,
    end,
    message,
    "choose a valid Ordering for this atomic operation"
  )
}

pub fn simdErrorDiagnostic(file: u32, start: usize, end: usize, message: string) -> LowLevelErrorDiagnostic {
  return lowLevelErrorDiagnostic(
    LowLevelErrorDiagnosticKind.Simd,
    file,
    start,
    end,
    message,
    "enable a supported target feature or use the scalar fallback"
  )
}

pub fn layoutErrorDiagnostic(file: u32, start: usize, end: usize, message: string) -> LowLevelErrorDiagnostic {
  return lowLevelErrorDiagnostic(
    LowLevelErrorDiagnosticKind.Layout,
    file,
    start,
    end,
    message,
    "use a stable layout, explicit alignment, or portable Binary encoding"
  )
}

