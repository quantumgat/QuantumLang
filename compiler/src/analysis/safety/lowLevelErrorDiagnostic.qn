  return lowLevelErrorDiagnostic(
    LowLevelErrorDiagnosticKind.Ffi,
    file,
    start,
    end,
    message,
    "wrap the call in an FFI boundary with typed error translation"
  )
}

pub fn coredumpRiskDiagnostic(file: u32, start: usize, end: usize, message: string) -> LowLevelErrorDiagnostic {
  return lowLevelErrorDiagnostic(
    LowLevelErrorDiagnosticKind.CoredumpRisk,
    file,
    start,
    end,
    message,
    "route the failure through crashless RuntimeReport emission"
  )
}

pub fn doubleFreeRiskDiagnostic(file: u32, start: usize, end: usize, message: string) -> LowLevelErrorDiagnostic {
  return lowLevelErrorDiagnostic(
    LowLevelErrorDiagnosticKind.DoubleFreeRisk,
    file,
    start,
    end,
    message,
    "remove the second release or transfer ownership before freeing"
  )
}

impl LowLevelErrorDiagnosticKind {
  pub fn category(self: LowLevelErrorDiagnosticKind) -> DiagnosticCategory {
    match self {
      LowLevelErrorDiagnosticKind.Memory => { return DiagnosticCategory.Memory }
      LowLevelErrorDiagnosticKind.Pointer => { return DiagnosticCategory.Memory }
      LowLevelErrorDiagnosticKind.Unsafe => { return DiagnosticCategory.Unsafe }
      LowLevelErrorDiagnosticKind.Atomic => { return DiagnosticCategory.Atomic }
      LowLevelErrorDiagnosticKind.Simd => { return DiagnosticCategory.Simd }
      LowLevelErrorDiagnosticKind.Layout => { return DiagnosticCategory.Layout }
      LowLevelErrorDiagnosticKind.Ffi => { return DiagnosticCategory.Ffi }
      LowLevelErrorDiagnosticKind.CoredumpRisk => { return DiagnosticCategory.Runtime }
      LowLevelErrorDiagnosticKind.DoubleFreeRisk => { return DiagnosticCategory.Ownership }
    }
  }

  pub fn proofKind(self: LowLevelErrorDiagnosticKind) -> ProofDiagnosticKind {
    match self {
      LowLevelErrorDiagnosticKind.Memory => { return ProofDiagnosticKind.Memory }
      LowLevelErrorDiagnosticKind.Pointer => { return ProofDiagnosticKind.Pointer }
      LowLevelErrorDiagnosticKind.Unsafe => { return ProofDiagnosticKind.UnsafeObligation }
      LowLevelErrorDiagnosticKind.Atomic => { return ProofDiagnosticKind.AtomicOrder }
      LowLevelErrorDiagnosticKind.Simd => { return ProofDiagnosticKind.SimdTarget }
      LowLevelErrorDiagnosticKind.Layout => { return ProofDiagnosticKind.Layout }
      LowLevelErrorDiagnosticKind.Ffi => { return ProofDiagnosticKind.FfiBoundary }
      LowLevelErrorDiagnosticKind.CoredumpRisk => { return ProofDiagnosticKind.CoredumpRisk }
      LowLevelErrorDiagnosticKind.DoubleFreeRisk => { return ProofDiagnosticKind.DoubleFreeRisk }
    }
  }

  pub fn codeNumber(self: LowLevelErrorDiagnosticKind) -> u32 {
    match self {
      LowLevelErrorDiagnosticKind.Memory => { return 2001 }
      LowLevelErrorDiagnosticKind.Pointer => { return 2002 }
      LowLevelErrorDiagnosticKind.Unsafe => { return 2003 }
      LowLevelErrorDiagnosticKind.Atomic => { return 2004 }
      LowLevelErrorDiagnosticKind.Simd => { return 2005 }
      LowLevelErrorDiagnosticKind.Layout => { return 2006 }
      LowLevelErrorDiagnosticKind.Ffi => { return 2007 }
      LowLevelErrorDiagnosticKind.CoredumpRisk => { return 2008 }
      LowLevelErrorDiagnosticKind.DoubleFreeRisk => { return 2009 }
    }
  }

  pub fn proofCode(self: LowLevelErrorDiagnosticKind) -> string {
    return "LOW"
  }

  pub fn ruleName(self: LowLevelErrorDiagnosticKind) -> string {
    match self {
      LowLevelErrorDiagnosticKind.Memory => { return "memory-safety" }
      LowLevelErrorDiagnosticKind.Pointer => { return "pointer-safety" }
      LowLevelErrorDiagnosticKind.Unsafe => { return "unsafe-obligation" }
      LowLevelErrorDiagnosticKind.Atomic => { return "atomic-ordering" }
      LowLevelErrorDiagnosticKind.Simd => { return "simd-target-gate" }
      LowLevelErrorDiagnosticKind.Layout => { return "layout-proof" }
      LowLevelErrorDiagnosticKind.Ffi => { return "ffi-boundary" }
      LowLevelErrorDiagnosticKind.CoredumpRisk => { return "crashless-failure" }
      LowLevelErrorDiagnosticKind.DoubleFreeRisk => { return "double-free-proof" }
    }
  }
}

impl LowLevelErrorDiagnostic {
  pub fn reportable(self: LowLevelErrorDiagnostic) -> bool {
    return self.diagnostic.complete()
      && self.machine.safe()
      && self.proof.reportable()
      && self.fixIt.applicable()
      && self.range.exact()
      && self.safeFixItOnly
      && self.noCoredumpPath
      && self.redacted
  }
}
