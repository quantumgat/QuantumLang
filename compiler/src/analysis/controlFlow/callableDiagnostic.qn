pub enum CallableDiagnosticKind {
  ParameterCountMismatch
  ReturnTypeMismatch
  CaptureOutlivesSource
  MutableCaptureNotAllowed
  AsyncCallableRequiresAwait
  HotCallbackHeapCapture
}

pub struct CallableDiagnostic {
  kind: CallableDiagnosticKind,
  code: string,
  sourceRangeReady: bool,
  fixitReady: bool,
}

impl CallableDiagnostic {
  pub fn complete(self: CallableDiagnostic) -> bool {
    return self.code != ""
      && self.sourceRangeReady
      && self.fixitReady
  }
}
