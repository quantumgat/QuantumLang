fn bsonExactBinaryValue(value: BsonExactValue) -> BsonValue
fn bsonExactCarrierValue(value: BsonExactValue) -> BsonValue
fn bsonExactValue<T>(value: T) -> Result<BsonValue, BsonError>
fn bsonValueFrom<T>(value: T) -> Result<BsonValue, BsonError>
fn bsonValueWithPath(value: BsonValue, path: string) -> BsonValue
fn bsonValueAsBool(value: BsonValue) -> Result<bool, BsonError>
fn bsonValueAsI8(value: BsonValue) -> Result<i8, BsonError>
fn bsonValueAsU8(value: BsonValue) -> Result<u8, BsonError>
