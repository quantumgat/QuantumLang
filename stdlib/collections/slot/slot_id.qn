pub struct SlotId {
  index: usize,
  generation: usize,
}

impl SlotId {
  pub fn empty() -> SlotId {
    return SlotId {
      index: 0,
      generation: 0,
    }
  }

  pub fn new(index: usize, generation: usize) -> SlotId {
    return SlotId {
      index: index,
      generation: generation,
    }
  }

  pub fn isEmpty(self: SlotId) -> bool {
    return self.generation == 0
  }
}
