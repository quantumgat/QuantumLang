pub struct BoundedChannel<T> {
  sender: Sender<T>,
  receiver: Receiver<T>,
  capacity: usize,
  backpressure: Backpressure,
}

impl BoundedChannel<T> {
  pub fn sender(self: BoundedChannel<T>) -> Sender<T> {
    return self.sender
  }

  pub fn receiver(self: BoundedChannel<T>) -> Receiver<T> {
    return self.receiver
  }

  pub fn isBackpressured(self: BoundedChannel<T>) -> bool {
    return self.capacity > 0 && self.backpressure == Backpressure.Block
  }
}
