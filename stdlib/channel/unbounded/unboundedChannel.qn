pub struct UnboundedChannel<T> {
  sender: Sender<T>,
  receiver: Receiver<T>,
  memoryBounded: bool,
}

impl UnboundedChannel<T> {
  pub fn sender(self: UnboundedChannel<T>) -> Sender<T> {
    return self.sender
  }

  pub fn receiver(self: UnboundedChannel<T>) -> Receiver<T> {
    return self.receiver
  }

  pub fn safe(self: UnboundedChannel<T>) -> bool {
    return self.memoryBounded
  }
}
