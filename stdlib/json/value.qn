fn jsonMergeObjectKernel(value: JsonValue, fields: JsonValue, mode: JsonMergeMode) -> Result<JsonValue, JsonError>
fn jsonMergeArrayKernel(value: JsonValue, elements: JsonValue, mode: JsonMergeMode) -> Result<JsonValue, JsonError>
fn jsonRemoveFieldKernel(value: JsonValue, name: string) -> Result<JsonValue, JsonError>
fn jsonPushElementKernel(value: JsonValue, element: JsonValue) -> Result<JsonValue, JsonError>
fn jsonRemoveElementKernel(value: JsonValue, index: usize) -> Result<JsonValue, JsonError>
fn jsonHasPathKernel(value: JsonValue, path: string) -> bool
fn jsonGetPathKernel(value: JsonValue, path: string) -> Result<JsonValue, JsonError>
fn jsonSetPathKernel(value: JsonValue, path: string, fieldValue: JsonValue) -> Result<JsonValue, JsonError>
