pub enum MathRuntimeError {
  Overflow,
  DivideByZero,
  InvalidShift,
  InvalidScale,
  ResourceLimit,
  UnsupportedTargetFeature,
  ComplexDomain,
  ZeroModulus,
  NonInvertible,
  DimensionMismatch,
}

impl MathRuntimeError {
  pub fn safe(self: MathRuntimeError) -> bool {
    return true
  }
}
