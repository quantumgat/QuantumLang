pub struct SecretAccessPolicy {
  branchlessRequired: bool,
  dataIndependentMemory: bool,
  redactionRequired: bool,
}

impl SecretAccessPolicy {
  pub fn strict() -> SecretAccessPolicy {
    return SecretAccessPolicy {
      branchlessRequired: true,
      dataIndependentMemory: true,
      redactionRequired: true,
    }
  }

  pub fn accepted(self: SecretAccessPolicy) -> bool {
    return self.branchlessRequired && self.dataIndependentMemory && self.redactionRequired
  }
}
