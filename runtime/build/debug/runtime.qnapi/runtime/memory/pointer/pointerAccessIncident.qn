// qtlc package API surface for runtime; bodies are supplied by the native package archive.
pub enum PointerAccessIncidentKind {
  NullDereference,
  OutOfBounds,
  ProvenanceRejected,
  MisalignedAccess,
  UseAfterFree,
  DoubleDrop,
  WeakUpgradeExpired,
  MoveWhilePinned,
}
pub struct PointerAccessIncident {
  kind: PointerAccessIncidentKind
  allocationId: u64
  coredump: bool
  diagnosticCode: string
}
