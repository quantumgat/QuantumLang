// qtlc package API surface for runtime; bodies are supplied by the native package archive.
pub enum CancellationIncidentKind {
  StaleToken
  CleanupMissing
  DeadlineRace
  StaleWake
}
pub struct CancellationIncident {
  kind: CancellationIncidentKind
  tokenId: u64
  diagnosticCode: string
  noCoredump: bool
}
