// qtlc package API surface for runtime; bodies are supplied by the native package archive.
pub enum CancellationCleanupKind {
  TaskFrame
  TimerEntry
  ChannelWaiter
  ReactorRegistration
}
pub struct CancellationCleanup {
  tokenId: u64
  kind: CancellationCleanupKind
  cleanupEdges: usize
  noAllocationRequired: bool
}
