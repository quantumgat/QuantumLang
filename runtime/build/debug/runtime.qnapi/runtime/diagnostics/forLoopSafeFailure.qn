// qtlc package API surface for runtime; bodies are supplied by the native package archive.
pub enum ForLoopSafeFailureKind {
  NonIterable
  InvalidPattern
  InvalidStep
  ParallelCaptureViolation
  AsyncAwaitRequired
  UnsafeRequired
  QuantumProfileViolation
}
pub struct ForLoopSafeFailure {
  kind: ForLoopSafeFailureKind
  sourceRangeReady: bool
  fixitReady: bool
  noCoredump: bool
  recoverable: bool
  executableNegativeCovered: bool
}
