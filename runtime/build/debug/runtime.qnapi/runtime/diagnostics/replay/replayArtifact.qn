// qtlc package API surface for runtime; bodies are supplied by the native package archive.
pub struct ReplayArtifact {
  path: string
  incidentId: u64
  logEventSequence: u64
  schemaName: string
  deterministic: bool
  redacted: bool
  retained: bool
  testReady: bool
  noCompilerDependency: bool
}
pub extern "qnpkg" {
  pub fn replayArtifact(path: string) -> ReplayArtifact
}
