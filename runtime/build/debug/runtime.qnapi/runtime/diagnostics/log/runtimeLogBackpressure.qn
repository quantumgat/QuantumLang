// qtlc package API surface for runtime; bodies are supplied by the native package archive.
pub enum RuntimeLogBackpressureKind {
  DropNewest,
  DropOldest,
  BlockCaller,
  SpillToIncident,
  ReturnError,
}
pub struct RuntimeLogBackpressure {
  kind: RuntimeLogBackpressureKind
  queueCapacity: usize
  dropCount: usize
  returnsTypedError: bool
  neverAllocatesOnPressure: bool
  incidentFallback: bool
  noPanic: bool
  noCoredump: bool
}
