// qtlc package API surface for runtime; bodies are supplied by the native package archive.
pub struct RuntimeTraceSpan {
  spanId: u64
  parentId: u64
  traceId: u64
  taskId: u64
  actorId: u64
  requestId: string
  correlationId: string
  cancellationId: u64
  subsystem: string
  asyncPropagated: bool
  causalChainPreserved: bool
  lowOverhead: bool
}
pub extern "qnpkg" {
  pub fn runtimeTraceSpan(spanId: u64, parentId: u64, subsystem: string) -> RuntimeTraceSpan
}
