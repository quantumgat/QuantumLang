// qtlc package API surface for runtime; bodies are supplied by the native package archive.
pub struct PrintErrorLogRuntimePolicy {
  stdoutStderrNoPanic: bool
  logsRedactedBeforeSink: bool
  incidentsStructured: bool
  noCoredumpForSafeFailures: bool
  partialWritesPreserved: bool
}
pub extern "qnpkg" {
  pub fn printErrorLogRuntimePolicy() -> PrintErrorLogRuntimePolicy
}
