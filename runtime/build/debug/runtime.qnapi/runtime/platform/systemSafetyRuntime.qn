// qtlc package API surface for runtime; bodies are supplied by the native package archive.
pub enum RuntimeSystemSafetyKind {
  Filesystem
  Path
  Environment
  Process
  Terminal
  Signal
  SysCapability
  SysTargetGate
  SysUnsupported
  RawHandle
}
pub struct RuntimeSystemSafety {
  kind: RuntimeSystemSafetyKind
  capabilityChecked: bool
  memoryBounded: bool
  blockingBounded: bool
  incidentRecorded: bool
  noCoredump: bool
}
