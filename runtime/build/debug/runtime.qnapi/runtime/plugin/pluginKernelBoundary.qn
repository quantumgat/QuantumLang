// qtlc package API surface for runtime; bodies are supplied by the native package archive.
pub struct PluginKernelBoundary {
  allocatorDomainChecked: bool
  noUnwindAcrossBoundary: bool
  capabilityTokensChecked: bool
  memoryIncidentSafe: bool
  schedulerIncidentSafe: bool
  resourceLimitsChecked: bool
}
