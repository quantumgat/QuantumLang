// qtlc package API surface for runtime; bodies are supplied by the native package archive.
pub enum WhileAsyncLoopHandoffKind {
  AwaitQuestion
  Timeout
  Poll
}
pub struct WhileAsyncLoopHandoff {
  kind: WhileAsyncLoopHandoffKind
  reactorReady: bool
  deadlineReady: bool
  cancellationReady: bool
  cleanupRegistered: bool
  pollSourceRegistered: bool
  noCoredump: bool
}
