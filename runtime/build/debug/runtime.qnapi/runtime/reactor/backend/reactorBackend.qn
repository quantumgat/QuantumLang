// qtlc package API surface for runtime; bodies are supplied by the native package archive.
pub enum RuntimeReactorBackendKind {
  LinuxEpoll
  LinuxIoUring
  MacosKqueue
  WindowsIocp
  Portable
}
pub struct RuntimeReactorBackend {
  kind: RuntimeReactorBackendKind
  target: string
  supportsTimers: bool
  supportsCancellation: bool
  deterministicTestable: bool
}
