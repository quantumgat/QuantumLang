// qtlc package API surface for runtime; bodies are supplied by the native package archive.
pub abstract class WindowsFileSystem {
  root: string
  mounted: bool
  pub init(root: string) {}
  pub fn providerName(self: &WindowsFileSystem) -> string
  pub fn supportsAtomicRename(self: &WindowsFileSystem) -> bool
  pub fn supportsSymlink(self: &WindowsFileSystem) -> bool
  pub fn supportsStreaming(self: &WindowsFileSystem) -> bool
  pub fn noCoredump(self: &WindowsFileSystem) -> bool
}
