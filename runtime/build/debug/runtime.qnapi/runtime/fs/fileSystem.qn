// qtlc package API surface for runtime; bodies are supplied by the native package archive.
pub interface FileSystem {
  pub fn providerName(self: &FileSystem) -> string
  pub fn supportsAtomicRename(self: &FileSystem) -> bool
  pub fn supportsSymlink(self: &FileSystem) -> bool
  pub fn supportsStreaming(self: &FileSystem) -> bool
  pub fn noCoredump(self: &FileSystem) -> bool
}
