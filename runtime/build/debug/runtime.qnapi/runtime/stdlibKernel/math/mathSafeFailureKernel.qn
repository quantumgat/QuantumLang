// qtlc package API surface for runtime; bodies are supplied by the native package archive.
pub enum MathRuntimeIncidentKind {
  Overflow
  DivideByZero
  InvalidShift
  InvalidScale
  ResourceLimit
  UnsupportedTargetFeature
  ComplexDomain
}
pub struct MathSafeFailureKernel {
  incidentKind: MathRuntimeIncidentKind
  sourceMapped: bool
  typedError: bool
  emergencyNoAllocation: bool
  noCoredump: bool
}
