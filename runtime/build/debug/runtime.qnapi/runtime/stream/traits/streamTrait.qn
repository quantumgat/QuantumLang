// qtlc package API surface for runtime; bodies are supplied by the native package archive.
pub enum StreamTraitKind {
  ReadableStream
  WritableStream
  SeekableStream
  ReplayableStream
}
pub struct StreamTrait {
  kind: StreamTraitKind
  capabilityChecked: bool
}
pub extern "qnpkg" {
  pub fn streamTrait(kind: StreamTraitKind) -> StreamTrait
}
