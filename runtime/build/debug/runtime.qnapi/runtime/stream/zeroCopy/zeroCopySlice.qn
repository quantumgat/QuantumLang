// qtlc package API surface for runtime; bodies are supplied by the native package archive.
pub struct ZeroCopySlice {
  ownerHandle: u64
  offset: usize
  byteLength: usize
  provenanceExplicit: bool
}
pub extern "qnpkg" {
  pub fn zeroCopySlice(ownerHandle: u64, offset: usize, byteLength: usize) -> ZeroCopySlice
}
