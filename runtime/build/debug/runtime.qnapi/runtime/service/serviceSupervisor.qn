// qtlc package API surface for runtime; bodies are supplied by the native package archive.
pub abstract class ServiceSupervisor {
  serviceCount: usize
  running: bool
  pub init() {}
  pub fn start(self: &mut ServiceSupervisor) -> bool
  pub fn shutdown(self: &mut ServiceSupervisor) -> bool
  pub fn drop(self: &mut ServiceSupervisor) -> bool
  pub fn ownsServices(self: &ServiceSupervisor) -> bool
}
