// qtlc package API surface for runtime; bodies are supplied by the native package archive.
pub enum RuntimeAtomicOperationKind {
  Load,
  Store,
  ReadModifyWrite,
  CompareExchange,
  Wait,
  Wake,
  Fence,
}
pub struct RuntimeMemoryOrderPolicy {
  operation: RuntimeAtomicOperationKind
  order: RuntimeMemoryOrder
}
