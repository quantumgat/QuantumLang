// qtlc package API surface for runtime; bodies are supplied by the native package archive.
pub enum DropBehaviorKind {
  NoDrop
  DirectDrop
  InterfaceErasedDrop
}
pub struct DropBehavior {
  typeId: u64
  dropFnPtr: u64
  kind: DropBehaviorKind
  panicSafe: bool
}
pub extern "qnpkg" {
  pub fn dropBehavior(typeId: u64, dropFnPtr: u64, kind: DropBehaviorKind, panicSafe: bool) -> DropBehavior
}
