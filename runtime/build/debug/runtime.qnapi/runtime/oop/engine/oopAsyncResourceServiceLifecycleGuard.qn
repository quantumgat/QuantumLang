// qtlc package API surface for runtime; bodies are supplied by the native package archive.
pub struct OopAsyncResourceServiceLifecycleGuard {
  objectId: u64
  ownerTypeName: string
  generation: u64
  started: bool
  ready: bool
  healthy: bool
  shutdownRequested: bool
  shutdownCompleted: bool
  reconnectInFlight: bool
  typedFailureBound: bool
  noCoredumpFailure: bool
}
