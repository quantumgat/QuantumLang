// qtlc package API surface for runtime; bodies are supplied by the native package archive.
pub struct OopAsyncMethodRuntimeGuard {
  objectId: u64
  ownerTypeName: string
  methodName: string
  generation: u64
  receiverActive: bool
  awaitSuspended: bool
  cancellationRequested: bool
  cleanupCompleted: bool
  partialInitCleanupCompleted: bool
  typedFailureBound: bool
  noCoredumpFailure: bool
  sourceMapBound: bool
}
