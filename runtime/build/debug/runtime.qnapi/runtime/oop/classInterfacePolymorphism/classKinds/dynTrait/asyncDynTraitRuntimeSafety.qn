// qtlc package API surface for runtime; bodies are supplied by the native package archive.
pub struct AsyncDynTraitRuntimeSafety {
  dynTypeId: u64
  dataPointerBound: bool
  adapterTableBound: bool
  futureFrameBound: bool
  pollEntryBound: bool
  generationChecked: bool
  cancellationCleanupBound: bool
  staleHandleRejected: bool
  typedFailureNoCoredumpBound: bool
  sourceMapBound: bool
}
