// qtlc package API surface for runtime; bodies are supplied by the native package archive.
pub struct CachedDispatch {
  callSiteId: u64
  methodPtr: u64
  resolvedBeforeLoop: bool
}
pub extern "qnpkg" {
  pub fn cachedDispatch(callSiteId: u64, methodPtr: u64, resolvedBeforeLoop: bool) -> CachedDispatch
}
