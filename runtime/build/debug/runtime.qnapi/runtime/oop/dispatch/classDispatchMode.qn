// qtlc package API surface for runtime; bodies are supplied by the native package archive.
pub enum ClassDispatchMode {
  FinalDirect
  SealedTable
  OpenVtable
  CachedDynamic
  FullDynamic
}
pub struct ClassDispatchPlan {
  mode: ClassDispatchMode
  hotPath: bool
}
pub extern "qnpkg" {
  pub fn classDispatchPlan(mode: ClassDispatchMode, hotPath: bool) -> ClassDispatchPlan
}
