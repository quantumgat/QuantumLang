// qtlc package API surface for runtime; bodies are supplied by the native package archive.
pub struct RuntimeOwnershipGraph {
  pub runtimeOwnsScheduler: bool
  pub runtimeOwnsAllocator: bool
  pub runtimeOwnsQirBridge: bool
  pub schedulerOwnsWorkerPool: bool
  pub qirBridgeOwnsProviderDispatch: bool
}
pub extern "qnpkg" {
  pub fn runtimeOwnershipGraph() -> RuntimeOwnershipGraph
}
