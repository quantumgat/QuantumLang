// qtlc package API surface for runtime; bodies are supplied by the native package archive.
pub struct ParallelLoopHighLevelRuntime {
  threads: usize
  batch: usize
  workSourceChecked: bool
  stopResultChecked: bool
  cleanupChecked: bool
  noCoredump: bool
}
pub extern "qnpkg" {
  pub fn parallelLoopHighLevelRuntime(
  threads: usize,
  batch: usize,
  workSourceChecked: bool,
  stopResultChecked: bool,
  cleanupChecked: bool,
  noCoredump: bool,
) -> ParallelLoopHighLevelRuntime
}
