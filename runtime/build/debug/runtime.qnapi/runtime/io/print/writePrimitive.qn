// qtlc package API surface for runtime; bodies are supplied by the native package archive.
pub enum RuntimePrintWriteKind {
  Stdout,
  Stderr,
  Target,
  Emergency,
}
pub struct RuntimePrintWrite {
  kind: RuntimePrintWriteKind
  target: RuntimePrintTarget
  request: IoRequest
  result: IoResult
  partial: PartialWrite
  directLiteralEligible: bool
  retryOnInterrupted: bool
  preservesOrder: bool
  returnsResult: bool
  noPanic: bool
  noCoredump: bool
}
