// qtlc package API surface for runtime; bodies are supplied by the native package archive.
pub enum RuntimePrintTargetKind {
  Stdout,
  Stderr,
  Terminal,
  File,
  Test,
}
pub struct RuntimePrintTarget {
  kind: RuntimePrintTargetKind
  handleId: u64
  terminalAware: bool
  preservesOrder: bool
  returnsResult: bool
}
