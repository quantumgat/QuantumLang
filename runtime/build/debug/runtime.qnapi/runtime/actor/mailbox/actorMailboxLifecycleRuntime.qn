// qtlc package API surface for runtime; bodies are supplied by the native package archive.
pub struct ActorMailboxLifecycleRuntime {
  actorId: ActorId
  mailboxBound: bool
  acceptingMessages: bool
  draining: bool
  drained: bool
  shutdownRequested: bool
  backpressureReady: bool
  serializedStateAccess: bool
  noCoredumpFailure: bool
}
