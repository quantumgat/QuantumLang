// qtlc package API surface for runtime; bodies are supplied by the native package archive.
pub enum RuntimeWaitWakeStatus {
  Woken,
  TimedOut,
  Cancelled,
  NotEqual,
  Unsupported,
  StaleHandle,
}
pub struct RuntimeWaitWake {
  token: WaitToken
  guardAware: bool
  cancellationSafe: bool
  staleHandleRejected: bool
  missedWakeDiagnostic: bool
  noCoredumpDiagnostic: bool
}
