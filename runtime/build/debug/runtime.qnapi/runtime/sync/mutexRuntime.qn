// qtlc package API surface for runtime; bodies are supplied by the native package archive.
pub enum RuntimeMutexIncidentKind {
  DoubleUnlock,
  UnlockWithoutOwner,
  Poisoned,
  StaleHandle,
}
pub struct RuntimeMutexGuard {
  handle: SyncHandle
  ownerThread: u64
  state: LockState
  unlockConsumed: bool
  noCoredumpDiagnostic: bool
}
