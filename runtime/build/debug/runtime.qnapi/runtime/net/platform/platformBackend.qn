// qtlc package API surface for runtime; bodies are supplied by the native package archive.
pub enum RuntimeNetPlatformKind {
  Epoll
  IoUring
  Kqueue
  Iocp
  Portable
}
pub struct RuntimeNetPlatformBackend {
  kind: RuntimeNetPlatformKind
  bestAvailable: bool
  deterministicTestBackend: bool
}
