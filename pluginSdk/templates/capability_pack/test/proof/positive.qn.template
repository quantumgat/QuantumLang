pub struct TemplatePositiveProof {
  manifestLoaded: bool,
  stdlibMounted: bool,
  compilerHookLoaded: bool,
  runtimeKernelLoaded: bool,
}

pub fn templatePositiveProof() -> TemplatePositiveProof {
